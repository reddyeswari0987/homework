#include <stdio.h>

#define MAX 10

int queue[MAX];
int front = -1, rear = -1;

// Insert process into ready queue
void enqueue(int pid) {
    if (rear == MAX - 1) {
        printf("Ready Queue is Full!\n");
        return;
    }

    if (front == -1)
        front = 0;

    queue[++rear] = pid;
    printf("Process %d added to Ready Queue.\n", pid);
}

// Remove process from ready queue
int dequeue() {
    if (front == -1 || front > rear) {
        printf("Ready Queue is Empty!\n");
        return -1;
    }

    return queue[front++];
}

// Display ready queue
void display() {
    if (front == -1 || front > rear) {
        printf("Ready Queue is Empty!\n");
        return;
    }

    printf("Ready Queue: ");
    for (int i = front; i <= rear; i++) {
        printf("%d ", queue[i]);
    }
    printf("\n");
}

int main() {
    enqueue(101);
    enqueue(102);
    enqueue(103);

    display();

    int running = dequeue();
    printf("Process %d is now running.\n", running);

    display();

    enqueue(104);

    display();

    return 0;
}
