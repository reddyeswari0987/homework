#include <stdio.h>
#include <stdlib.h>

int main() {
    FILE *fp;
    char data[100];

    // Write to file
    fp = fopen("sample.txt", "w");

    if (fp == NULL) {
        printf("Error opening file for writing.\n");
        return 1;
    }

    fprintf(fp, "Hello, this is a file system example.\n");
    fprintf(fp, "Operating Systems Lab\n");

    fclose(fp);

    printf("Data written successfully.\n\n");

    // Read from file
    fp = fopen("sample.txt", "r");

    if (fp == NULL) {
        printf("Error opening file for reading.\n");
        return 1;
    }

    printf("Contents of the file:\n");

    while (fgets(data, sizeof(data), fp) != NULL) {
        printf("%s", data);
    }

    fclose(fp);

    return 0;
}
